`pragma protect end_protected
module write_fifo (
  Data,
  WrReset,
  RdReset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Rnum,
  Q,
  Empty,
  Full
)
;
input [31:0] Data;
input WrReset;
input RdReset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [9:0] Rnum;
output [127:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.write_fifo  fifo_inst (
    .RdClk(RdClk),
    .RdReset(RdReset),
    .WrClk(WrClk),
    .WrReset(WrReset),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[31:0]),
    .Empty(Empty),
    .Full(Full),
    .Rnum(Rnum[9:0]),
    .Q(Q[127:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* write_fifo */
