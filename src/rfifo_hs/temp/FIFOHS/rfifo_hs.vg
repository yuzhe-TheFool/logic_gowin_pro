`pragma protect end_protected
module read_fifo (
  Data,
  WrReset,
  RdReset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Wnum,
  Rnum,
  Q,
  Empty,
  Full
)
;
input [127:0] Data;
input WrReset;
input RdReset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [9:0] Wnum;
output [12:0] Rnum;
output [15:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.read_fifo  fifo_inst (
    .RdClk(RdClk),
    .RdReset(RdReset),
    .WrClk(WrClk),
    .WrReset(WrReset),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[127:0]),
    .Empty(Empty),
    .Full(Full),
    .Wnum(Wnum[9:0]),
    .Rnum(Rnum[12:0]),
    .Q(Q[15:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* read_fifo */
